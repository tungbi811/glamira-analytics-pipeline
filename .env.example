# ── MongoDB Configuration ───────────────────────────────────────────
# Optional helper used by shell scripts and MONGO_URI interpolation
VM_EXTERNAL_IP=localhost
# Connection string for the MongoDB instance
MONGO_URI=mongodb://${VM_EXTERNAL_IP}:27017
# Name of the database containing the event data
DB_NAME=countly

# ── Google Cloud Configuration ──────────────────────────────────────
# GCP Project ID
GCP_PROJECT=your-project-id
# BigQuery Dataset for raw data
BQ_DATASET=glamira_raw
# BigQuery Location (e.g., US, EU, australia-southeast1)
BQ_LOCATION=australia-southeast1

# ── GCS Bucket Paths ────────────────────────────────────────────────
# Paths should include the gs:// prefix and end with a slash
GCS_SUMMARY_PATH=gs://unigap/glamira-data/processed/summary/
GCS_IP_PATH=gs://unigap/glamira-data/processed/ip_locations/
GCS_PRODUCT_PATH=gs://unigap/glamira-data/processed/product_details/

# ── Local File Paths ────────────────────────────────────────────────
# Base directory for local data storage
DATA_DIR=data
# Directory for log files
LOGS_DIR=logs
# Path to the IP2Location binary database file
IP2LOCATION_BIN_PATH=data/raw/ip2location.bin
# Output directories for exported JSONL files
SUMMARY_OUTPUT_DIR=data/processed/summary
IP_OUTPUT_DIR=data/processed/ip_locations
PRODUCT_OUTPUT_DIR=data/processed/product_details
# Product crawler error log
PRODUCT_LOG_FILE=logs/crawl_errors.log

# ── Processing Settings ─────────────────────────────────────────────
# Number of records to process in a single batch
BATCH_SIZE=100000

# ── Collection Names ────────────────────────────────────────────────
UNIQUE_IP_COLLECTION=unique_ips
IP_OUTPUT_COLLECTION=ip_locations
SUMMARY_COLLECTION=summary
PRODUCT_INPUT_COLLECTION=product_urls
PRODUCT_OUTPUT_COLLECTION=product_details
